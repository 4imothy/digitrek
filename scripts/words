#!/usr/bin/env python
import urllib.request

URL = "https://raw.githubusercontent.com/hackerb9/gwordlist/master/frequency-alpha-alldicts.txt"
TARGET = 2000
words_by_length = {3: [], 4: [], 5: [], 6: []}
seen = set()

with urllib.request.urlopen(URL) as r:
    for line in r:
        line = line.decode('utf-8').strip()
        if line.startswith('#') or not line:
            continue
        parts = line.split()
        if len(parts) < 2:
            continue
        word = parts[1].lower()
        length = len(word)
        if word.isalpha() and word.isascii() and length in words_by_length and word not in seen and len(words_by_length[length]) < TARGET:
            words_by_length[length].append(word)
            seen.add(word)
        if all(len(v) >= TARGET for v in words_by_length.values()):
            break

for length, words in words_by_length.items():
    with open(f'assets/words_{length}.rs', 'w') as f:
        f.write('[\n')
        for word in words:
            f.write(f'    "{word}",\n')
        f.write(']')
    print(f'words_{length}.rs: {len(words)} words')
